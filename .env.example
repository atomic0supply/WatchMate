# TMDB_API_KEY: optional, used by the client to fetch poster/metadata.
VITE_TMDB_API_KEY="YOUR_TMDB_API_KEY"

# The Gemini API key is NOT a client-side env var.
# It lives as a Firebase Functions secret. To set it:
#   firebase functions:secrets:set GEMINI_API_KEY
# (the CLI will prompt for the value and store it in Secret Manager).
